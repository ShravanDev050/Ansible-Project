# This file is managed by Ansible
# chrony configuration for Active Directory environment

pool 0.pool.ntp.org iburst
pool 1.pool.ntp.org iburst
pool 2.pool.ntp.org iburst
pool 3.pool.ntp.org iburst

# Use NTP sources from ad_ntp_servers variable
{% for ntp_server in ad_ntp_servers %}
server {{ ntp_server }} iburst
{% endfor %}

# This directive specify the location of the file containing ID/key pairs for
# NTP authentication.
keyfile /etc/chrony.keys

# This directive specify the file where to log measurements, statistics, and
# tracking information.  Statistics data are written to the file every night
# at midnight.  See documentation for file format details.  This log file is
# useful as a way to view recent chrony activity and estimate how well or
# poorly the system's clock is keeping time.
logdir /var/log/chrony

# Stop bad estimates upsetting machines on my network
maxdistance 16

# This directive forces `chronyd' to work in isolated mode, as though
# no other time sources were reachable.  Useful for machines which
# are cut off from networking for periods of time in order to prevent
# their clocks from running far into the future.
# offline

# This directive is ignored.  It is accepted for compatibility with older
# configuration files.
# corrtimeratio 0

# This option enables kernel synchronization (every 11 minutes) of the
# real-time clock. Note that it can't be used along with the 'rtcfile'
# directive.
rtcsync

# Step the system clock instead of slewing it if the adjustment is larger than
# one second, but only in the first three clock updates.
makestep 1 3

# Enable local stratum
local stratum 10
